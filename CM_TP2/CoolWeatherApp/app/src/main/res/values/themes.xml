<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CoolWeatherAPP" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name ="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color . -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color . -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here . -->
        <item name="background">@color/dark_grey</item>
        <item name="android:textColor">@color/yellow_500</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.Day" parent="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/weatherapp_bg </item>
    </style>
    <style name="Theme.Day.Land" parent="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/weatherapp_bg_land </item>
    </style>
    <style name="Theme.Night" parent ="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/weathernight_bg</item>
    </style>
    <style name="Theme.Night.Land" parent ="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/weathernight_bg_land</item>
    </style>

    <style name="Theme.CoolWeatherAPP" parent="Base.Theme.CoolWeatherAPP" />
</resources>