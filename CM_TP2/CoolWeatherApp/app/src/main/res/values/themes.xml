<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CoolWeatherAPP" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name ="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color . -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color . -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here . -->
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name = "WeatherThemeDay" parent="Base.Theme.CoolWeatherAPP">
        <item name="android:background">@color/purple_700_transparent</item>
        <item name="android:textColor">@color/yellow_500</item>
    </style>

    <style name = "WeatherThemeDayBackground" parent="Base.Theme.CoolWeatherAPP">
        <item name="android:background">@drawable/weatherapp_bg</item>
    </style>

    <style name = "WeatherThemeDayLand" parent="Base.Theme.CoolWeatherAPP">
        <item name="android:background">@color/purple_700_transparent</item>
        <item name="android:textColor">@color/yellow_500</item>
    </style>

    <style name = "WeatherThemeNight" parent="Base.Theme.CoolWeatherAPP">
        <item name="android:background">@color/black_transparent</item>
        <item name="android:textColor">@color/teal_700</item>
    </style>

    <style name = "WeatherThemeNightBackground" parent="Base.Theme.CoolWeatherAPP">
        <item name="android:background">@drawable/weathernight_bg</item>
    </style>

    <style name = "WeatherThemeNightLand" parent="Base.Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/weathernight_bg_land</item>
        <item name="android:background">@color/black_transparent</item>
        <item name="android:textColor">@color/teal_700</item>
    </style>


</resources>